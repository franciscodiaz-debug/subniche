APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=abc-123

# Database connection — composed from parts via dotenv-expand (supported by Next.js and Prisma).
# DB_HOST:   aws-x-region.pooler.supabase.com   (from Supabase dashboard → Settings → Database)
# DB_USER:   postgres.your-project-ref
# DB_SCHEMA: dev | qa | production | preview
#
# Local dev values below — replace with your Supabase project values for deployed envs.
DB_HOST=127.0.0.1
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=dev

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:6543/postgres?pgbouncer=true&schema=${DB_SCHEMA}
DIRECT_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:5432/postgres?schema=${DB_SCHEMA}

JWT_SECRET=change-me-to-a-long-random-secret
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
